localhost:
  hosts:
    '127.0.0.1':
      ansible_connection: local
oc_mirror:
  children:
    connected_mirror:
    disconnected_mirror:

connected_mirror:
  hosts:
    mirror-ext.lab.naramajac.xyz:
      ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

disconnected_mirror:
  hosts:
    mirror-int.lab.naramajac.xyz:
      ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
